<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:gravity="center"
    tools:context=".ui.detail.DetailFragment">
    <ImageView
        android:id="@+id/ivCard"
        android:layout_width="match_parent"
        android:layout_height="@dimen/xxxxxxxxxl"
        android:contentDescription="@string/todo"
        android:scaleType="fitCenter"
        android:src="@drawable/giratinaex"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_weight="1">
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/tvCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/category"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:textSize="@dimen/tx_m"
                    android:text="@string/dot"/>
                <TextView
                    android:id="@+id/tvRarity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/rarity"/>
            </LinearLayout>
        </LinearLayout>
        <TextView
            android:id="@+id/tvPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:text="@string/price"/>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/xl"
        android:weightSum="2"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="@dimen/xxxxl">
    <com.google.android.material.button.MaterialButton
        android:id="@+id/mbCollect"
        android:layout_weight="1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/xs"
        app:icon="@drawable/ic_add_box"
        android:text="@string/add_to_collection"
        app:cornerRadius="@dimen/s" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/mbEdit"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/xs"
            app:icon="@drawable/ic_edit"
            android:text="@string/edit"
            app:cornerRadius="@dimen/s" />
    </LinearLayout>


</LinearLayout>